# DataNexus environment variables
# Copy to .env.local and fill in your values

# Prisma / app database (stores app registry, keys, audit log)
DATABASE_URL="postgresql://datanexus_user:yourpassword@localhost:5432/datanexus"

# Admin Postgres connection (used to provision schemas for registered apps)
# Must have CREATEDB / CREATEROLE privileges
PG_HOST=localhost
PG_PORT=5432
PG_DB=datanexus
PG_ADMIN_USER=datanexus_admin
PG_ADMIN_PASSWORD=yourpassword

# Public host shown in generated connection strings
APP_DB_HOST=your-vps-ip-or-domain
APP_DB_PORT=5432
APP_DB_NAME=datanexus
